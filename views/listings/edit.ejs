<% layout("/layouts/boilerplate")%>
<body>
<div class="form-container">

  <h3 class="form-heading">Edit Listing</h3>

  <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">

    <div class="form-group">
      <label>Title</label>
      <input name="listing[title]" value="<%= listing.title %>" type="text" required>
    </div>

    <div class="form-group">
      <label>Description</label>
      <textarea name="listing[description]" required><%= listing.description %></textarea>
    </div>

    <div class="form-group">
      <label>Image URL</label>
      <input name="listing[image]" value="<%= listing.image.url %>" type="text">
    </div>

    <div class="form-group">
      <label>Price (₹)</label>
      <input name="listing[price]" value="<%= listing.price %>" type="number" required>
    </div>

    <div class="form-group">
      <label>Location</label>
      <input name="listing[location]" value="<%= listing.location %>" type="text" required>
    </div>

    <div class="form-group">
      <label>Country</label>
      <input name="listing[country]" value="<%= listing.country %>" type="text" required>
    </div>

    <button class="btn-submit">Update Listing</button>

  </form>

</div>

</body>